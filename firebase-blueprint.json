{
  "entities": {
    "Project": {
      "title": "Project",
      "description": "A portfolio project entry",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Project title" },
        "category": { "type": "string", "description": "Project category" },
        "image": { "type": "string", "description": "Image URL" },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "Tech stack tags" },
        "link": { "type": "string", "description": "Project URL" },
        "order": { "type": "integer", "description": "Display order" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "category", "image"]
    },
    "Service": {
      "title": "Service",
      "description": "A service tier offering",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "price": { "type": "string" },
        "description": { "type": "string" },
        "deliverables": { "type": "array", "items": { "type": "string" } },
        "cta": { "type": "string" },
        "color": { "type": "string" }
      },
      "required": ["title", "price", "description"]
    },
    "BlogPost": {
      "title": "Blog Post",
      "description": "A technical article",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "excerpt": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string" },
        "date": { "type": "string" },
        "readTime": { "type": "string" }
      },
      "required": ["title", "excerpt", "content"]
    },
    "Lead": {
      "title": "Lead",
      "description": "A project discovery submission",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "budget": { "type": "string" },
        "timeline": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "budget", "timeline", "email"]
    },
    "User": {
      "title": "User",
      "description": "A registered user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Order": {
      "title": "Order",
      "description": "A system order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "systemType": { "type": "string" },
        "options": { "type": "array", "items": { "type": "string" } },
        "totalPrice": { "type": "number" },
        "currency": { "type": "string", "enum": ["BDT", "USD"] },
        "paymentMethod": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "processing", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "systemType", "totalPrice", "currency", "status"]
    },
    "Visitor": {
      "title": "Visitor",
      "description": "A tracked site visitor",
      "type": "object",
      "properties": {
        "ip": { "type": "string" },
        "userAgent": { "type": "string" },
        "platform": { "type": "string" },
        "vendor": { "type": "string" },
        "language": { "type": "string" },
        "screenResolution": { "type": "string" },
        "location": { "type": "object" },
        "deviceInfo": { "type": "object" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["timestamp"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A message in the live chat",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "uid", "timestamp"]
    }
  },
  "firestore": {
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Portfolio projects"
    },
    "/services/{serviceId}": {
      "schema": "Service",
      "description": "Service tiers"
    },
    "/blogPosts/{postId}": {
      "schema": "BlogPost",
      "description": "Blog articles"
    },
    "/leads/{leadId}": {
      "schema": "Lead",
      "description": "Lead submissions"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "System orders"
    },
    "/visitors/{visitorId}": {
      "schema": "Visitor",
      "description": "Visitor tracking"
    },
    "/chat_messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Live chat messages"
    }
  }
}
